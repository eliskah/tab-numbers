{
  "manifest_version": 2,

  "name": "Numbered Tabs",
  "description": "See order of your open tabs to navigate easily",
  "version": "0.1",

  "browser_specific_settings": {
    "gecko": {
      "id": "tab-numbers@eliskah"
    }
  },

  "permissions": [
    "tabs",
    "storage",
    "file://*/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "commands" : {
    "toggle_title" : {
      "suggested_key" : {
        "default": "Alt+T"
      },
      "description": "Triggers title change"
    }
  }
}
